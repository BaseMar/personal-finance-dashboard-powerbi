{
  "name": "Personal Finance CV Theme",
  "dataColors": [
    "#3F72AF",
    "#112D4E",
    "#DBE2EF",
    "#F9F7F7"
  ],
  "foreground": "#112D4E",
  "foregroundNeutralSecondary": "#3F72AF",
  "foregroundNeutralTertiary": "#DBE2EF",
  "background": "#F9F7F7",
  "backgroundLight": "#DBE2EF",
  "backgroundNeutral": "#DBE2EF",
  "tableAccent": "#3F72AF",
  "good": "#3F72AF",
  "neutral": "#DBE2EF",
  "bad": "#112D4E",
  "maximum": "#3F72AF",
  "center": "#DBE2EF",
  "minimum": "#F9F7F7",
  "null": "#DBE2EF",
  "hyperlink": "#3F72AF",
  "visitedHyperlink": "#112D4E",
  "textClasses": {
    "callout": {
      "fontSize": 26,
      "fontFace": "Segoe UI Semibold",
      "color": "#112D4E"
    },
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#112D4E"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#112D4E"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#112D4E"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "*": [
          {
            "wordWrap": true
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#F9F7F7"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#DBE2EF"
              }
            },
            "width": 1
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#112D4E"
              }
            },
            "backgroundColor": {
              "solid": {
                "color": "#F9F7F7"
              }
            },
            "titleWrap": true
          }
        ],
        "categoryAxis": [
          {
            "showAxisTitle": false,
            "gridlineStyle": "dotted",
            "gridlineColor": {
              "solid": {
                "color": "#DBE2EF"
              }
            },
            "concatenateLabels": false
          }
        ],
        "valueAxis": [
          {
            "showAxisTitle": false,
            "gridlineStyle": "dotted",
            "gridlineColor": {
              "solid": {
                "color": "#DBE2EF"
              }
            }
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#F9F7F7"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F9F7F7"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "background": [
          {
            "show": false,
            "transparency": 100
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "shape": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "pageNavigator": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#F9F7F7"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#DBE2EF"
              }
            },
            "width": 1
          }
        ]
      }
    }
  }
}
